# ── Node (client + server) ───────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ── Build output ──────────────────────────────────────────────────────────────
client/dist/
client/.vite/

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
server/.env

